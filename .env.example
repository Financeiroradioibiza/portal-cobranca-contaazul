# Postgres (ex.: Neon) — obrigatório para guardar tokens OAuth
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Conexão **direct** (host SEM "-pooler") — só para `prisma migrate deploy` / `db push`.
# No painel Neon: Connection details → Direct connection.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"
# Rodada inicial Planilha Rio (MARCA+PDV offline): `npm run rio:apply-marca-layout -- YYYYMM` lê `.env` e depois `.env.local`.
# Use o Neon **pooled** (host com pooler) igual ao site. Opcional só para esse comando, se DATABASE_URL ficar exemplo:
# DATABASE_POOL_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# NEON_DATABASE_URL="postgresql://…"  # outro nome que por vezes aparece nos snippets Neon
# Se quiseres Postgres em localhost mesmo (raro): RIO_CLI_ALLOW_LOCAL_POSTGRES=1 ao correr MARCA+
# OAuth app Conta Azul (Portal do Desenvolvedor)
CONTA_AZUL_CLIENT_ID=""
CONTA_AZUL_CLIENT_SECRET=""
# Deve ser idêntico ao cadastrado no portal, ex.:
# CONTA_AZUL_REDIRECT_URI="https://seu-site.netlify.app/api/contaazul/callback"
CONTA_AZUL_REDIRECT_URI="http://localhost:3000/api/contaazul/callback"
#
# Opcional — só mudar se a URL base do PDF público do boleto iugu diferir da padrão (public.contaazul.com/.../charge/file).
# CONTA_AZUL_PUBLIC_BILLING_CHARGE_FILE_BASE="https://public.contaazul.com/payments/billing/charge/file"

# URL canônica do site (produção). Usada se o callback precisar montar redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Portal (login: usuário + senha + Google Authenticator / TOTP) ---
# Segredo para assinar cookie de sessão (mínimo 32 caracteres). Ex.: openssl rand -base64 32
PORTAL_SESSION_SECRET=""
# JSON em uma linha: array de usuários com hash bcrypt da senha e secret TOTP em Base32.
# Gerar hash: npm run portal:hash-password -- "sua_senha"
# Gerar secret TOTP: npm run portal:totp-secret  (cadastrar no app Google Authenticator manualmente ou QR depois)
# PORTAL_USERS_JSON='[{"username":"financeiro1","passwordHash":"$2a$12$....","totpSecret":"JBSWY3DPEHPK3PXP"}]'
PORTAL_USERS_JSON=""
# Apenas desenvolvimento local: "true" desabilita o login (não use em produção).
# PORTAL_AUTH_DISABLED="true"

# --- Painel Ibiza (`painel.radioibiza.com.br`) — prototipo `/api/radio-painel/query` ---
# RADIO_PAINEL_ENABLED="1"
# RADIO_PAINEL_BASE_URL="https://painel.radioibiza.com.br"
# RADIO_PAINEL_EMAIL="usuario@..."
# RADIO_PAINEL_PASSWORD="..."
# RADIO_PAINEL_SESSION_COOKIE="CAKEPHP=..."
# RADIO_PAINEL_CLIENTES_INDEX_SEARCH_PATH="/adm/clientes/index?buscaCliente={q}"
# RADIO_PAINEL_PROXY_SECRET=""
#
# Caminho absoluto alternativo ao `data/export-clientes.csv` na raiz do projecto
# RADIO_PAINEL_EXPORT_CSV_PATH="/caminho/export.csv"
#
# 1 = fallback frágil via HTML se planilha não tiver match (manter 0 quando possível)
# RADIO_PAINEL_HTML_SEARCH_FALLBACK="0"

# --- SMTP Locaweb (/manual «Disparar e-mail OC») — use os dados SMTP da mailboxes locaweb.com.br ---
# OC_EMAIL_SMTP_HOST=""
# OC_EMAIL_SMTP_PORT="587"
# OC_EMAIL_SMTP_SECURE="0"
# OC_EMAIL_SMTP_USER="cobranca@radioibiza.com.br"
# OC_EMAIL_SMTP_PASS=""
# OC_EMAIL_FROM="cobranca@radioibiza.com.br"
# Modelo também usado pelo e-mail agregado de «cobranças em aberto» no painel principal (/api/cobranca-aberta/*).
# OC_EMAIL_FROM_NAME="Radio Ibiza — Cobrança"
#
# Cc visível para o cliente — padrão cobranca@radioibiza.com.br em todos os envios SMTP (`sendEmailViaSmtp`).
# OC_EMAIL_CC_COBRANCA="cobranca@radioibiza.com.br"
# OC_EMAIL_CC_EXTRA=""
#
# BCC opcional para outros internos — não duplica Para nem Cc já cobertos.
# OC_EMAIL_BCC_COBRANCA="cobranca@radioibiza.com.br"
# OC_EMAIL_BCC_EXTRA=""
# OC_EMAIL_REPLY_TO=""

# --- Cron opcional: envio automático de pedido de OC (uma vez ao dia em horário Brasília → GET ou POST nesta URL) ---
# /api/manual-envios/oc-email/auto-dispatch com header Authorization: Bearer <SEGREDO>
# Mínimo 16 caracteres. Pode usar CRON_SECRET se já existir para outros jobs (senão OC_EMAIL_CRON_SECRET).
# OC_EMAIL_CRON_SECRET=""

# Competência inicial da Planilha Rio (painel `/planilha-rio`): YYYYMM, ex.: 202605 (Maio/2026)
# RIO_PLANILHA_START_YM="202605"

# Sync Planilha Rio: padrão servidor para buscar contratos na CA (lento). Em geral deixe comentado.
# RIO_SYNC_CONTRACTS_DEFAULT="1"
# Idem para enriquecimento por /v1/pessoas?ids (e-mail cobrança, etc.).
# RIO_SYNC_PERSON_DETAILS_DEFAULT="1"