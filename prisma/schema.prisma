model PortalConfig {
  chave     String   @id @db.VarChar(120)
  valor     String   @default("") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @default("") @map("updated_by") @db.VarChar(200)

  @@map("portal_config")
}

enum ChamadoStatus {
