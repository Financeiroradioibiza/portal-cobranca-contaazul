enum PlayerIngestTipo {
  feedback
  cadastro
}

enum PlayerIngestStatus {
  pendente
  conciliado
  arquivado
}

/// Recebimentos do Player 5 (feedback operador, atualização de cadastro).
model PlayerIngest {
  id               String             @id @default(cuid())
  tipo             PlayerIngestTipo
  status           PlayerIngestStatus @default(pendente)
  clienteGatewayId Int?               @map("cliente_gateway_id")
