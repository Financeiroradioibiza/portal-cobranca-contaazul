// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Conexão direta (sem pooler) — obrigatória para `prisma migrate` no Neon.
  directUrl = env("DIRECT_DATABASE_URL")
}

/// Um único registro com os tokens OAuth da empresa conectada ao Conta Azul.
model ContaAzulToken {
  id           String   @id @default("default")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("conta_azul_token")
}

/// Anotações do portal por cliente Conta Azul (id da pessoa). Persistem no Postgres mesmo quando
/// o cliente deixa de aparecer na listagem (ex.: zerou pendências na Conta Azul).
model ClientPortalMeta {
  clientId              String    @id @map("client_id")
  hasActiveContract     Boolean   @default(false) @map("has_active_contract")
  /// Números de contratos ATIVO na CA (vírgulas), cache do painel de cobrança.
  activeContractNumbers String    @default("") @map("active_contract_numbers") @db.VarChar(400)
  contractsFetchedAt    DateTime? @map("contracts_fetched_at")
  note                  String    @default("")
  /// Portal only: marca manual «BLOQUEIO» na listagem principal.
  painelBloqueio        Boolean   @default(false) @map("painel_bloqueio")
  /// Portal only: marca manual «INATIVO» na listagem principal.
  painelInativo         Boolean   @default(false) @map("painel_inativo")
  /// Cliente especial (estrela) na listagem de vencidos — só visualização no portal.
  clienteDestaque       Boolean   @default(false) @map("cliente_destaque")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("client_portal_meta")
}

/// Status do fluxo OC / envio para um cliente num mês.
enum ManualReminderRowStatus {
  pendente
  solicitado_ordem
  enviado
}

/// Modelo de linhas (novos meses copiam daqui).
model ManualReminderTemplate {
  id                       String   @id @default(cuid())
  emissionDay              Int      @map("emission_day")
  clienteNome              String   @map("cliente_nome")
  cnpjDocumento            String?  @map("cnpj_documento")
  solicitarPedirOc         Boolean  @default(true) @map("solicitar_pedir_oc")
  /// Anexar listagem (clientes mês anterior) ao e-mail de pedido de OC, todo mês.
  anexarListagemClientesOc Boolean  @default(false) @map("anexar_listagem_clientes_oc")
  spreadsheetHint          String?  @map("spreadsheet_hint")
  sortOrder                Int      @default(0) @map("sort_order")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("manual_reminder_template")
}

/// Instância mensal (aba “Maio/2026”, etc.).
model ManualReminderMonth {
  id        String   @id @default(cuid())
  yearMonth Int      @unique @map("year_month")
  createdAt DateTime @default(now()) @map("created_at")

  linhas ManualReminderRow[]

  @@map("manual_reminder_month")
}

model ManualReminderRow {
  id      String              @id @default(cuid())
  monthId String              @map("month_id")
  month   ManualReminderMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  emissionDay       Int     @map("emission_day")
  clienteNome       String  @map("cliente_nome")
  cnpjDocumento     String? @map("cnpj_documento")
  contaAzulPersonId String? @map("conta_azul_person_id")

  solicitarPedirOc         Boolean                 @default(true) @map("solicitar_pedir_oc")
  /// Listagem/imagem dos clientes (mês anterior) a anexar ao e-mail OC; renovar a cada competência.
  anexarListagemClientesOc Boolean                 @default(false) @map("anexar_listagem_clientes_oc")
  status                   ManualReminderRowStatus @default(pendente)

  emailCobranca              String? @map("email_cobranca")
  spreadsheetHint            String? @map("spreadsheet_hint")
  notes                      String  @default("")
  listagemClienteArquivo     Bytes?  @map("listagem_cliente_arquivo") @db.ByteA
  listagemClienteArquivoNome String? @map("listagem_cliente_arquivo_nome") @db.VarChar(480)
  listagemClienteArquivoMime String? @map("listagem_cliente_arquivo_mime") @db.VarChar(160)

  /// YYYYMMDD (TZ Brasil): último envio automático OC; impede segundo disparo no mesmo dia (reset ao voltar para pendente).
  autoOcSentYmd Int? @map("auto_oc_sent_ymd")

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([monthId, emissionDay, sortOrder])
  @@map("manual_reminder_row")
}

/// Modelo único de e-mail para pedido de OC (Envios manuais). Id fixo `default`.
model OcEmailTemplate {
  id        String   @id
  subject   String
  bodyText  String   @map("body_text") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("oc_email_template")
}

/// Template do e-mail agregado «cobranças em aberto» na homepage (usa mesmo SMTP OC_*).
model CobrancaAbertaEmailTemplate {
  id        String   @id
  subject   String   @db.VarChar(480)
  bodyText  String   @map("body_text") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cobranca_aberta_email_template")
}

// --- Planilha Rio (visão competência mês a mês, amarrada ao Conta Azul) ---

enum RioPlanilhaBand {
  canceladas
  novos
  ativos
}

enum RioPlanilhaRowKind {
  secao
  grupo
  pdv
}

enum RioChargeMode {
  herda_grupo
  cliente_ca_proprio
}

model RioPlanilhaMonth {
  id        String   @id @default(cuid())
  yearMonth Int      @unique @map("year_month")
  createdAt DateTime @default(now()) @map("created_at")

  linhas RioPlanilhaRow[]

  @@map("rio_planilha_month")
}

model RioPlanilhaRow {
  id      String           @id @default(cuid())
  monthId String           @map("month_id")
  month   RioPlanilhaMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  band RioPlanilhaBand
  kind RioPlanilhaRowKind

  parentId String?          @map("parent_id")
  parent   RioPlanilhaRow?  @relation("RioPdvParent", fields: [parentId], references: [id], onDelete: Cascade)
  children RioPlanilhaRow[] @relation("RioPdvParent")

  /// Só em linhas `secao` — título da faixa (ex.: lojas canceladas).
  tituloSecao String? @map("titulo_secao") @db.Text

  marca         String  @default("")
  numOrdem      Int?    @map("num_ordem")
  pdvNome       String  @default("") @map("pdv_nome")
  cnpjDocumento String? @map("cnpj_documento")
  status        String  @default("")
  valorTexto    String? @map("valor_texto")
  qtdeTexto     String? @map("qtde_texto")
  categoria     String  @default("")
  email         String? @db.Text
  dataInstall   String? @map("data_install")
  grupoCobranca String  @default("") @map("grupo_cobranca") @db.Text
  razao         String  @default("") @db.Text
  dataCancel    String? @map("data_cancel")
  notes         String  @default("") @db.Text

  contaAzulPersonId String? @map("conta_azul_person_id")

  /// Em `pdv`: fatura pelo grupo (matriz) vs cliente próprio no CA.
  chargeMode RioChargeMode @default(herda_grupo) @map("charge_mode")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([monthId, sortOrder])
  @@index([monthId, band, sortOrder])
  @@map("rio_planilha_row")
}

/// --- Planilha Rio v2 — competências com clientes ativos Conta Azul + PDVs geridos no portal ---

enum RioClienteCompMovimento {
  estavel
  entrada
  saida
}

enum RioPdvMovimento {
  estavel
  entrada
  saida
}

enum RioTagCobranca {
  cobrando
  cancelado
  bloqueio_financeiro
}

model RioCompMonth {
  id              String    @id @default(cuid())
  yearMonth       Int       @unique @map("year_month")
  lastSyncedAt    DateTime? @map("last_synced_at")
  closedAt        DateTime? @map("closed_at")
  /// Backup imediato antes de «Sincronizar Conta Azul» (permite desfazer).
  preSyncSnapshot Json?     @map("pre_sync_snapshot")
  /// Listagem CA acumulada página a página na virada (junho+).
  viradaPrepare   Json?     @map("virada_prepare")
  /// Estado da cópia maio→junho em lotes (evita timeout Netlify).
  cloneDonorState Json?     @map("clone_donor_state")
  createdAt       DateTime  @default(now()) @map("created_at")

  grupos RioCompGrupo[]
  linhas RioCompClienteLinha[]

  @@map("rio_comp_month")
}

/// Marca agrupadora (PDF «MARCA») — arrastar clientes dentro no painel Rio.
model RioCompGrupo {
  id      String       @id @default(cuid())
  monthId String       @map("month_id")
  month   RioCompMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  nome      String  @default("") @map("nome") @db.Text
  sortOrder Int     @default(0) @map("sort_order")
  /// Blocos fixos da virada: ca_entrada, ca_saida, pdv_entrada, pdv_saida
  systemTag String? @map("system_tag") @db.VarChar(32)

  linhas RioCompClienteLinha[]

  @@index([monthId, sortOrder])
  @@map("rio_comp_grupo")
}

model RioCompClienteLinha {
  id      String       @id @default(cuid())
  monthId String       @map("month_id")
  month   RioCompMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  rioGrupoId String?       @map("rio_grupo_id")
  rioGrupo   RioCompGrupo? @relation(fields: [rioGrupoId], references: [id], onDelete: SetNull)

  caPersonId String @map("ca_person_id")

  /// Agrupamento interno — não existe no ERP.
  grupoSite String @default("") @map("grupo_site") @db.Text

  nomeFantasia  String  @default("") @map("nome_fantasia") @db.Text
  /// APP, OC ou PERMUTA — exibido em vermelho após o nome na coluna cliente.
  origemCliente String  @default("") @map("origem_cliente") @db.VarChar(10)
  razaoSocial   String  @default("") @map("razao_social") @db.Text
  documento     String? @db.VarChar(64)
  emailCobranca String? @map("email_cobranca") @db.Text

  // Texto livre (ex.: valor vindo da API CA ou traco)
  valorClienteTexto     String @default("") @map("valor_cliente_texto") @db.VarChar(200)
  /// Valor manual por PDV; total = unitário × numero_pdv_site
  valorPdvUnitarioTexto String @default("") @map("valor_pdv_unitario_texto") @db.VarChar(200)

  numeroPdvSite Int    @default(0) @map("numero_pdv_site")
  categoriaSite String @default("") @map("categoria_site") @db.VarChar(120)

  /// Número(s) de contratos ATIVO no CA quando sincronizou (lista separada por vírgulas).
  contratosAtivosTexto String @default("") @map("contratos_ativos_texto") @db.VarChar(400)

  movimento   RioClienteCompMovimento @default(estavel)
  tagCobranca RioTagCobranca          @default(cobrando) @map("tag_cobranca")

  observacoesLinha String @default("") @map("observacoes_linha") @db.Text
  sortOrder        Int    @default(0) @map("sort_order")

  /// ID numérico do cliente no Player (100, 101, … — ordem alfabética).
  portalClienteId Int? @unique @map("portal_cliente_id")

  pdvs RioCompPdv[]

  @@unique([monthId, caPersonId])
  @@index([monthId, sortOrder])
  @@map("rio_comp_cliente_linha")
}

model RioCompPdv {
  id        String              @id @default(cuid())
  clienteId String              @map("cliente_id")
  cliente   RioCompClienteLinha @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  nome        String          @default("") @db.Text
  /// CNPJ/CPF do PDV para vínculo com cadastro de produção.
  documento   String?         @db.VarChar(64)
  notes       String          @default("") @db.Text
  sortOrder   Int             @default(0) @map("sort_order")
  movimento   RioPdvMovimento @default(estavel)
  tagCobranca RioTagCobranca  @default(cobrando) @map("tag_cobranca")

  /// ID numérico do PDV no Player (ex. 100001 → exibido 100.001).
  portalPdvId Int? @unique @map("portal_pdv_id")

  createdAt DateTime @default(now()) @map("created_at")

  painelLink PainelPdvLink?

  @@index([clienteId, sortOrder])
  @@map("rio_comp_pdv")
}

/// Login de cliente no Player (email + senha → lista de PDVs).
model ClientePlayerLogin {
  id              String   @id @default(cuid())
  portalClienteId Int      @unique @map("portal_cliente_id")
  email           String   @unique @db.VarChar(200)
  passwordHash    String   @map("password_hash") @db.Text
  /// Senha em texto para consulta do suporte (estável até edição manual).
  passwordPlain   String   @default("") @map("password_plain") @db.VarChar(64)
  clienteNome     String   @default("") @map("cliente_nome") @db.Text
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("cliente_player_login")
}

/// Aviso vermelho exibido no Player 5 (par portal cliente + PDV).
model PlayerAvisoOperador {
  id              String   @id @default(cuid())
  portalClienteId Int      @map("portal_cliente_id")
  portalPdvId     Int      @map("portal_pdv_id")
  mensagem        String   @db.Text
  /// Agrupa avisos «todos PDVs do cliente» — desativação e listagem em uma linha.
  batchId         String?  @map("batch_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([portalClienteId, portalPdvId])
  @@index([batchId])
  @@map("player_aviso_operador")
}

/// Logotipo JPEG do cliente no Player 5 (sync → gateway `clientes.logotipo_jpeg`).
model PlayerClienteLogotipo {
  portalClienteId Int      @id @map("portal_cliente_id")
  jpegBase64      String   @map("jpeg_base64") @db.Text
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("player_cliente_logotipo")
}

/// Vínculo PDV Planilha Rio ↔ painel legado (produção).
enum PainelMatchMethod {
  cnpj
  nome_pdv
  nome_cliente
  manual
}

model PainelPdvLink {
  id           String     @id @default(cuid())
  rioCompPdvId String     @unique @map("rio_comp_pdv_id")
  rioCompPdv   RioCompPdv @relation(fields: [rioCompPdvId], references: [id], onDelete: Cascade)

  painelPdvId     Int               @map("painel_pdv_id")
  painelClienteId Int               @map("painel_cliente_id")
  matchMethod     PainelMatchMethod @map("match_method")

  painelPdvNome     String? @map("painel_pdv_nome") @db.Text
  painelClienteNome String? @map("painel_cliente_nome") @db.Text

  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([painelPdvId])
  @@map("painel_pdv_link")
}

/// Layout da coluna Produção (nomes editados + arrastes) por competência.
model CadastroProducaoLayout {
  yearMonth                   Int       @id @map("year_month")
  clienteNomes                Json      @default("{}") @map("cliente_nomes")
  pdvPlacements               Json      @default("[]") @map("pdv_placements")
  hiddenClienteKeys           Json      @default("[]") @map("hidden_cliente_keys")
  customClientes              Json      @default("[]") @map("custom_clientes")
  acknowledgedPdvs            Json      @default("[]") @map("acknowledged_pdvs")
  /// IDs com movimento «entrada» congelados na organização inicial — não entram em pendências.
  movimentoBaselineEntradaIds Json      @default("[]") @map("movimento_baseline_entrada_ids")
  /// IDs com movimento «saída» congelados na organização inicial — não entram em encerrados.
  movimentoBaselineSaidaIds   Json      @default("[]") @map("movimento_baseline_saida_ids")
  /// Quando a produção foi considerada organizada (baseline aplicada).
  movimentoOrganizedAt        DateTime? @map("movimento_organized_at")
  /// portalClienteId (100+) por bucket da produção (`custom:…` ou rioLinhaId).
  portalClienteIdsByBucketKey Json      @default("{}") @map("portal_cliente_ids_by_bucket_key")
  /// portalPdvId (100.001…) por rioPdvKey — fonte única operacional (nunca em rio_comp_*).
  portalPdvIdsByRioPdvKey     Json      @default("{}") @map("portal_pdv_ids_by_rio_pdv_key")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@map("cadastro_producao_layout")
}

enum ProducaoPlayerStatus {
  Ativo
  Inativo
}

/// Cadastro operacional do PDV na produção musical.
model ProducaoPdvCadastro {
  rioPdvKey String @id @map("rio_pdv_key")

  nome               String               @default("") @db.Text
  programacaoMusical String               @default("Padrão") @map("programacao_musical") @db.VarChar(120)
  /// Programação musical amarrada a este PDV (Central de programações).
  programacaoId      String?              @map("programacao_id")
  versaoPlayer       String               @default("") @map("versao_player") @db.VarChar(64)
  cep                String               @default("") @db.VarChar(16)
  endereco           String               @default("") @db.Text
  numero             String               @default("") @db.VarChar(32)
  complemento        String               @default("") @db.VarChar(120)
  bairro             String               @default("") @db.VarChar(120)
  estado             String               @default("") @db.VarChar(8)
  cidade             String               @default("") @db.VarChar(120)
  razaoSocial        String               @default("") @map("razao_social") @db.Text
  cnpj               String               @default("") @db.VarChar(64)
  placaCarro         Boolean              @default(false) @map("placa_carro")
  controlarPlayer    Boolean              @default(false) @map("controlar_player")
  controlarPlaylist  Boolean              @default(false) @map("controlar_playlist")
  statusPlayer       ProducaoPlayerStatus @default(Ativo) @map("status_player")

  /// Código «contato extra» no Player 5: ALERTACORTE | CADASTRO (vazio = nenhum).
  playerContatoExtraCodigo String @default("") @map("player_contato_extra_codigo") @db.VarChar(32)

  contatoLojaNome     String @default("") @map("contato_loja_nome") @db.Text
  contatoLojaEmail    String @default("") @map("contato_loja_email") @db.Text
  contatoLojaTelefone String @default("") @map("contato_loja_telefone") @db.VarChar(64)

  contatoCobrancaNome     String @default("") @map("contato_cobranca_nome") @db.Text
  contatoCobrancaEmail    String @default("") @map("contato_cobranca_email") @db.Text
  contatoCobrancaTelefone String @default("") @map("contato_cobranca_telefone") @db.VarChar(64)

  /// Chave serial do Player (1ª instalação amarra o aparelho).
  playerInstalacaoToken String    @default("") @map("player_instalacao_token") @db.VarChar(64)
  playerInstaladoEm     DateTime? @map("player_instalado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  programacao Programacao? @relation(fields: [programacaoId], references: [id], onDelete: SetNull)

  @@index([programacaoId])
  @@map("producao_pdv_cadastro")
}

/// Perfil de acesso (Admin, Financeiro, Suporte…) — permissões por menu.
model PortalProfile {
  id              String   @id @default(cuid())
  slug            String   @unique @db.VarChar(40)
  name            String   @db.VarChar(80)
  icon            String   @default("👤") @db.VarChar(8)
  description     String   @default("") @db.Text
  /// JSON: permissões por módulo (ver lib/portal/menuPermissions.ts).
  permissionsJson String   @default("{}") @map("permissions_json") @db.Text
  /// Papéis derivados para JWT / middleware (master, cobranca, …).
  rolesJson       String   @default("[]") @map("roles_json") @db.Text
  isSystem        Boolean  @default(true) @map("is_system")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users PortalUser[]

  @@map("portal_profile")
}

/// Usuário do portal (e-mail + senha + TOTP).
model PortalUser {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(200)
  displayName  String    @default("") @map("display_name") @db.VarChar(120)
  jobTitle     String    @default("") @map("job_title") @db.VarChar(120)
  passwordHash String    @map("password_hash") @db.Text
  totpSecret   String    @map("totp_secret") @db.VarChar(64)
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  profileId    String    @map("profile_id")
  /// Iniciais no chip de tag criativa — ex.: RG, LA
  tagIniciais  String    @default("") @map("tag_iniciais") @db.VarChar(8)
  /// Cor hex padrão das tags deste criativo
  tagCor       String    @default("#6366f1") @map("tag_cor") @db.VarChar(9)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  profile   PortalProfile    @relation(fields: [profileId], references: [id], onDelete: Restrict)
  auditLogs PortalAuditLog[]

  @@index([profileId])
  @@map("portal_user")
}

/// Registro de ações dos usuários no portal (auditoria).
model PortalAuditLog {
  id              String   @id @default(cuid())
  userEmail       String   @map("user_email") @db.VarChar(200)
  userDisplayName String   @default("") @map("user_display_name") @db.VarChar(120)
  userId          String?  @map("user_id")
  action          String   @db.VarChar(200)
  method          String   @db.VarChar(10)
  path            String   @db.VarChar(500)
  query           String   @default("") @db.VarChar(500)
  ip              String   @default("") @db.VarChar(64)
  userAgent       String   @default("") @map("user_agent") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")

  user PortalUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userEmail])
  @@map("portal_audit_log")
}

/// Log de ERROS do portal (client/server/api/render) — visível em Config › Erros.
/// Foco em desenvolvimento: capturar e exportar falhas para diagnóstico.
model PortalErrorLog {
  id        String   @id @default(cuid())
  /// "error" | "warn" | "info"
  level     String   @default("error") @db.VarChar(10)
  /// "client" | "render" | "api" | "server"
  source    String   @default("client") @db.VarChar(12)
  message   String   @db.Text
  stack     String   @default("") @db.Text
  /// Rota/URL onde ocorreu.
  path      String   @default("") @db.VarChar(500)
  method    String   @default("") @db.VarChar(10)
  /// Status HTTP quando for erro de API.
  status    Int?
  userEmail String   @default("") @map("user_email") @db.VarChar(200)
  userAgent String   @default("") @map("user_agent") @db.VarChar(500)
  /// Dados extras (payload, request id, etc.).
  context   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([level])
  @@index([source])
  @@map("portal_error_log")
}

/// Parâmetros globais do portal (chave-valor). Lido pelo portal e pelo worker do cloud2.
