// ============================================================================
// CRIAÇÃO MUSICAL — Fase 0 (modelo de dados)
// Portal = fonte de verdade. Os binários de áudio ficam em object storage
// (R2 quente + B2 frio); aqui guardamos só metadados/tags/relacionamentos.
// ============================================================================

enum MusicaProcessStatus {
  pendente
  processando
  revisao_duplicata
  pronta
  erro
}

/// Faixa canônica da biblioteca — UMA por gravação (dedupe por fingerprint).
model MusicaBiblioteca {
  id         String @id @default(cuid())
  titulo     String @default("") @db.Text
  artista    String @default("") @db.Text
  ano        Int?
  durationMs Int?   @map("duration_ms")

  /// Identificação / dedupe.
  isrc        String? @db.VarChar(32)
  acoustId    String? @map("acoust_id") @db.VarChar(64)
  /// Fingerprint Chromaprint (dedupe perceptual — mesma gravação em bitrates diferentes).
  chromaprint String? @db.Text
  /// Hash do áudio decodificado (sha256) — dedupe exato/secundário.
  contentHash String? @map("content_hash") @db.VarChar(80)

  /// Master 192k guardado no B2 (frio); só reprocessamos a partir dele.
  masterStorageKey String? @map("master_storage_key") @db.VarChar(300)
  masterBitrate    Int?    @map("master_bitrate")
  loudnessLufs     Float?  @map("loudness_lufs")
  truePeakDb       Float?  @map("true_peak_db")

  /// Tags automáticas estruturadas (análise local Essentia).
  bpm            Int?
  tom            String? @db.VarChar(16)
  energia        Float?
  valencia       Float?
  danceabilidade Float?
  acustico       Float?
  instrumental   Float?
  /// Tags soltas de fontes externas: [{fonte:"lastfm|deezer|musicbrainz|discogs", chave, valor}].
  tagsAuto       Json    @default("[]") @map("tags_auto")

  /// Ponto de mix: segundos finais onde começa o crossfade p/ a próxima faixa
  /// (detectado automaticamente pela queda de energia no fim; equivale ao "~4" do nome legado).
  mixSegundosFinais Int?    @map("mix_segundos_finais")
  /// false quando o criativo ajustou o ponto de mix manualmente na "Edição de música".
  mixAuto           Boolean @default(true) @map("mix_auto")
  /// Trim manual ("tapa"): corta início/fim em ms. Null = sem corte.
  trimInicioMs      Int?    @map("trim_inicio_ms")
  trimFimMs         Int?    @map("trim_fim_ms")

  status    MusicaProcessStatus @default(pendente)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tagsManuais MusicaTagManual[]
  versoes     MusicaVersao[]
  pastas      PastaMusica[]
  rejeicoes   MusicaRejeicao[]

  @@index([artista])
  @@index([titulo])
  @@index([isrc])
  @@index([acoustId])
  @@index([status])
  @@map("musica_biblioteca")
}

/// Tag criativa pessoal com cor própria. Ex.: "Lounge Style" amarelo do Lauro.
model TagCriativo {
  id             String   @id @default(cuid())
  nome           String   @db.VarChar(80)
  /// Cor do chip (hex) — padrão por criativo.
  cor            String   @default("#888888") @db.VarChar(9)
  criativoUserId String?  @map("criativo_user_id")
  criativoNome   String   @default("") @map("criativo_nome") @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at")

  musicas MusicaTagManual[]

  @@unique([nome, criativoUserId])
  @@index([criativoUserId])
  @@map("tag_criativo")
}

model MusicaTagManual {
  musicaId  String   @map("musica_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  musica MusicaBiblioteca @relation(fields: [musicaId], references: [id], onDelete: Cascade)
  tag    TagCriativo      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([musicaId, tagId])
  @@index([tagId])
  @@map("musica_tag_manual")
}

enum FormatoEntrega {
  mp3_128_mono
  mp3_128_stereo
  mp3_192_mono
  mp3_192_stereo
}

/// Versão de uso (transcodificada + .rib AES-256) por formato — no R2 quente.
model MusicaVersao {
  id         String         @id @default(cuid())
  musicaId   String         @map("musica_id")
  formato    FormatoEntrega
  /// Chave do arquivo .rib no storage quente (R2).
  storageKey String         @map("storage_key") @db.VarChar(300)
  sizeBytes  Int?           @map("size_bytes")
  createdAt  DateTime       @default(now()) @map("created_at")

  musica MusicaBiblioteca @relation(fields: [musicaId], references: [id], onDelete: Cascade)

  @@unique([musicaId, formato])
  @@map("musica_versao")
}

/// Programação musical amarrada a um cliente da produção.
model Programacao {
  id             String         @id @default(cuid())
  /// Cliente da produção: caPersonId estável quando houver; senão rioLinhaId/custom key.
  clienteRef     String         @map("cliente_ref") @db.VarChar(120)
  clienteNome    String         @default("") @map("cliente_nome") @db.VarChar(200)
  nome           String         @db.VarChar(120)
  formatoPadrao  FormatoEntrega @default(mp3_128_mono) @map("formato_padrao")
  publicada      Boolean        @default(false)
  publishedAt    DateTime?      @map("published_at")
  /// Revisão no ar (incrementa a cada disparo de atualização).
  revisionAtual  Int            @default(0) @map("revision_atual")
  /// Cliente do gateway Player 5 usado na publicação/disparo.
  clienteGatewayId Int?         @map("cliente_gateway_id")
  /// Snapshot das faixas por pasta após o último disparo (para diff do log).
  snapshotAtual  Json?          @map("snapshot_atual")
  /// Ciclo de edição aberto (Abrir atualização) — limpo ao Fechar/disparar.
  atualizacaoAbertaEm  DateTime? @map("atualizacao_aberta_em")
  atualizacaoAbertaPor String   @default("") @map("atualizacao_aberta_por") @db.VarChar(200)
  criativoUserId String?        @map("criativo_user_id")
  criativoNome   String         @default("") @map("criativo_nome") @db.VarChar(120)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  pastas       Pasta[]
  vinhetas     Vinheta[]
  agendamentos Agendamento[]
  atualizacoes     ProgramacaoAtualizacao[]
  pdvCadastros     ProducaoPdvCadastro[]
  painelAtualizacao CriacaoAtualizacaoPainel[]

  @@index([clienteRef])
  @@map("programacao")
}

enum TipoSubidaAtualizacao {
  install
  atl
  especial
}

/// Registro de cada disparo de atualização (log + diff entraram/saíram).
model ProgramacaoAtualizacao {
  id                  String                 @id @default(cuid())
  programacaoId       String                 @map("programacao_id")
  /// Rótulo legível: INSTALL, ATL Junho 1, ESPECIAL PASCOA…
  codigo              String                 @db.VarChar(80)
  tipoSubida          TipoSubidaAtualizacao  @default(atl) @map("tipo_subida")
  especialNome        String                 @default("") @map("especial_nome") @db.VarChar(80)
  competencia         String                 @default("") @map("competencia") @db.VarChar(7)
  rotuloLog           String                 @default("") @map("rotulo_log") @db.VarChar(120)
  clienteNomeLog      String                 @default("") @map("cliente_nome_log") @db.VarChar(200)
  programacaoNomeLog  String                 @default("") @map("programacao_nome_log") @db.VarChar(120)
  pdvsLog             String                 @default("") @map("pdvs_log") @db.VarChar(500)
  revision            Int
  disparadaEm         DateTime               @default(now()) @map("disparada_em")
  disparadaPor        String                 @default("") @map("disparada_por") @db.VarChar(200)
  /// { entraram: FaixaLog[], sairam: FaixaLog[] }
  diffJson            Json                   @map("diff_json")
  snapshotJson        Json                   @map("snapshot_json")
  musicasPublicadas   Int                    @default(0) @map("musicas_publicadas")
  playlistsPublicadas Int                    @default(0) @map("playlists_publicadas")

  programacao Programacao @relation(fields: [programacaoId], references: [id], onDelete: Cascade)

  @@index([programacaoId, disparadaEm])
  @@index([programacaoId, competencia])
  @@map("programacao_atualizacao")
}

/// Painel mensal de acompanhamento (Renato / produção) por programação.
model CriacaoAtualizacaoPainel {
  id                 String    @id @default(cuid())
  competencia        String    @db.VarChar(7)
  programacaoId      String    @map("programacao_id")
  clienteRef         String    @map("cliente_ref") @db.VarChar(120)
  clienteNome        String    @default("") @map("cliente_nome") @db.VarChar(200)
  programacaoNome    String    @default("") @map("programacao_nome") @db.VarChar(120)
  criativoEntregueEm DateTime? @map("criativo_entregue_em")
  criativoEntreguePor String   @default("") @map("criativo_entregue_por") @db.VarChar(200)
  subidaFilaEm       DateTime? @map("subida_fila_em")
  subidaFilaPor      String    @default("") @map("subida_fila_por") @db.VarChar(200)
  subidaFilaJobId    String?   @map("subida_fila_job_id")
  /// [{ rotulo, tipo, em, atualizacaoId }]
  fechamentosJson    Json      @default("[]") @map("fechamentos_json")

  programacao Programacao @relation(fields: [programacaoId], references: [id], onDelete: Cascade)

  @@unique([competencia, programacaoId])
  @@index([competencia])
  @@map("criacao_atualizacao_painel")
}

enum AgendamentoAlvo {
  pasta
  vinheta
}

/// Cronograma: quando uma pasta ou vinheta toca (dias da semana + janela de horário
/// + intervalo de datas opcional). Para vinhetas, frequenciaMin repete dentro da janela.
model Agendamento {
  id            String          @id @default(cuid())
  programacaoId String          @map("programacao_id")
  alvoTipo      AgendamentoAlvo @map("alvo_tipo")
  alvoId        String          @map("alvo_id")
  /// Dias da semana como CSV de 0..6 (0=domingo). Vazio = todos os dias.
  diasSemana    String          @default("") @map("dias_semana") @db.VarChar(32)
  horaInicio    String          @default("00:00") @map("hora_inicio") @db.VarChar(5)
  horaFim       String          @default("23:59") @map("hora_fim") @db.VarChar(5)
  /// Intervalo de datas (opcional): ex.: tocar de 07 a 10 de junho.
  dataInicio    DateTime?       @map("data_inicio") @db.Date
  dataFim       DateTime?       @map("data_fim") @db.Date
  /// Para vinhetas: tocar a cada N minutos dentro da janela (null = não usar intervalo por tempo).
  frequenciaMin Int?            @map("frequencia_min")
  /// Para vinhetas: tocar a cada N músicas da programação (null = não usar intervalo por faixa).
  frequenciaMusicas Int?        @map("frequencia_musicas")
  prioridade    Int             @default(0)
  ativo         Boolean         @default(true)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  programacao Programacao @relation(fields: [programacaoId], references: [id], onDelete: Cascade)

  @@index([programacaoId])
  @@index([alvoTipo, alvoId])
  @@map("agendamento")
}

/// Pasta/playlist dentro de uma programação.
model Pasta {
  id            String   @id @default(cuid())
  programacaoId String   @map("programacao_id")
  nome          String   @db.VarChar(120)
  /// "baixa" | "media" | "alta" — ritmo da pasta (campo do mockup).
  velocidade    String   @default("media") @db.VarChar(16)
  /// Só toca no player quando o operador seleciona na grade (não entra no slot automático).
  selecionavel  Boolean  @default(false)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  programacao Programacao   @relation(fields: [programacaoId], references: [id], onDelete: Cascade)
  musicas     PastaMusica[]

  @@index([programacaoId, sortOrder])
  @@map("pasta")
}

model PastaMusica {
  pastaId   String @map("pasta_id")
  musicaId  String @map("musica_id")
  sortOrder Int    @default(0) @map("sort_order")

  pasta  Pasta            @relation(fields: [pastaId], references: [id], onDelete: Cascade)
  musica MusicaBiblioteca @relation(fields: [musicaId], references: [id], onDelete: Cascade)

  @@id([pastaId, musicaId])
  @@index([musicaId])
  @@map("pasta_musica")
}

enum VinhetaTipo {
  tts
  audio
  ia
}

enum VinhetaStatus {
  rascunho
  gerando
  preview
  aprovada
}

/// Vinheta/aviso atrelável a uma programação.
model Vinheta {
  id               String        @id @default(cuid())
  programacaoId    String?       @map("programacao_id")
  nome             String        @db.VarChar(160)
  tipo             VinhetaTipo   @default(tts)
  status           VinhetaStatus @default(rascunho)
  texto            String        @default("") @db.Text
  voz              String        @default("") @db.VarChar(80)
  /// Voz ElevenLabs (nome exibido) — complementa `voz` (voice_id).
  vozNome          String        @default("") @map("voz_nome") @db.VarChar(120)
  trilhaMusicaId   String?       @map("trilha_musica_id")
  /// Trilha ambiente exclusiva do módulo Vinhetas (não entra na biblioteca musical).
  trilhaVinhetaId  String?       @map("trilha_vinheta_id")
  trilhaStorageKey String?       @map("trilha_storage_key") @db.VarChar(300)
  storageKey       String?       @map("storage_key") @db.VarChar(300)
  criativoUserId   String?       @map("criativo_user_id") @db.VarChar(200)
  criativoNome     String        @default("") @map("criativo_nome") @db.VarChar(120)
  aprovadaEm       DateTime?     @map("aprovada_em")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  programacao Programacao? @relation(fields: [programacaoId], references: [id], onDelete: SetNull)

  @@index([programacaoId])
  @@index([status, criativoUserId])
  @@map("vinheta")
}

/// Trilha ambiente para vinhetas IA — upload direto, visível só em Criação → Vinhetas.
model VinhetaTrilha {
  id             String   @id @default(cuid())
  nome           String   @db.VarChar(160)
  storageKey     String?  @map("storage_key") @db.VarChar(300)
  durationMs     Int?     @map("duration_ms")
  uploadedBy     String   @map("uploaded_by") @db.VarChar(200)
  uploadedByNome String   @default("") @map("uploaded_by_nome") @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([uploadedBy])
  @@map("vinheta_trilha")
}

enum JobTipo {
  upload_pasta
  enriquecer_tags
  transcode_cliente
}

enum JobStatus {
  aguardando
  processando
  revisao
  concluido
  erro
  cancelado
}

/// Job da fila de processamento (separada da fila do webservice do player).
model ProcessamentoJob {
  id           String    @id @default(cuid())
  tipo         JobTipo   @default(upload_pasta)
  status       JobStatus @default(aguardando)
  /// upload | normalizacao | deduplicacao | tags | criptografia | distribuicao
  etapaAtual   String    @default("upload") @map("etapa_atual") @db.VarChar(24)
  titulo       String    @default("") @db.VarChar(200)
  clienteRef   String?   @map("cliente_ref") @db.VarChar(120)
  clienteNome  String    @default("") @map("cliente_nome") @db.VarChar(200)
  criativoNome String    @default("") @map("criativo_nome") @db.VarChar(120)
  /// E-mail do criativo (para cor/iniciais da tag de upload)
  criativoUserId String? @map("criativo_user_id") @db.VarChar(200)
  /// Tag criativa definida no upload — ex.: POP 90s
  uploadTagNome  String  @default("") @map("upload_tag_nome") @db.VarChar(80)
  programacaoId  String? @map("programacao_id")
  pastaId        String? @map("pasta_id")
  totalItens   Int       @default(0) @map("total_itens")
  itensFeitos  Int       @default(0) @map("itens_feitos")
  erroMsg      String    @default("") @map("erro_msg") @db.Text
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  itens ProcessamentoItem[]

  @@index([status, createdAt])
  @@map("processamento_job")
}

enum ItemStatus {
  aguardando
  processando
  duplicata
  concluido
  erro
}

/// Item (arquivo) dentro de um job de processamento.
model ProcessamentoItem {
  id            String     @id @default(cuid())
  jobId         String     @map("job_id")
  arquivoNome   String     @default("") @map("arquivo_nome") @db.Text
  /// Storage do upload bruto (R2 temporário) antes de virar master.
  rawStorageKey String?    @map("raw_storage_key") @db.VarChar(300)
  status        ItemStatus @default(aguardando)
  /// Etapa do pipeline desta faixa (upload … armazenamento) — alimenta o Kanban da fila.
  etapaAtual    String     @default("upload") @map("etapa_atual") @db.VarChar(24)
  musicaId      String?    @map("musica_id")
  /// Quando duplicata: música existente que casou no fingerprint (decisão humana).
  duplicataDeId String?    @map("duplicata_de_id")
  erroMsg       String     @default("") @map("erro_msg") @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  job ProcessamentoJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@map("processamento_item")
}

/// Música rejeitada por um cliente — vira filtro no Wizard ("evitar rejeitadas").
model MusicaRejeicao {
  id         String   @id @default(cuid())
  musicaId   String   @map("musica_id")
  clienteRef String   @map("cliente_ref") @db.VarChar(120)
  motivo     String   @default("") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  musica MusicaBiblioteca @relation(fields: [musicaId], references: [id], onDelete: Cascade)

  @@unique([musicaId, clienteRef])
  @@index([clienteRef])
  @@map("musica_rejeicao")
}

enum DownloadProvider {
  spotizerr
  deemix
  youtube
}

enum DownloadJobStatus {
  aguardando
  processando
  concluido
  erro
  cancelado
}

enum DownloadItemStatus {
  aguardando
  processando
  concluido
  erro
}

/// Lote de downloads (Spotizerr / Deemix / YouTube) antes do upload.
model DownloadJob {
  id             String             @id @default(cuid())
  provider       DownloadProvider
  status         DownloadJobStatus  @default(aguardando)
  titulo         String             @default("") @db.VarChar(200)
  criativoNome   String             @default("") @map("criativo_nome") @db.VarChar(120)
  criativoUserId String?            @map("criativo_user_id") @db.VarChar(200)
  totalItens     Int                @default(0) @map("total_itens")
  itensFeitos    Int                @default(0) @map("itens_feitos")
  erroMsg        String             @default("") @map("erro_msg") @db.Text
  startedAt      DateTime?          @map("started_at")
  finishedAt     DateTime?          @map("finished_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  itens DownloadItem[]

  @@index([provider, status, createdAt])
  @@map("download_job")
}

model DownloadItem {
  id             String             @id @default(cuid())
  jobId          String             @map("job_id")
  linhaOriginal  String             @default("") @map("linha_original") @db.Text
  /// url | texto
  inputTipo      String             @default("texto") @map("input_tipo") @db.VarChar(16)
  status         DownloadItemStatus @default(aguardando)
  arquivoNome    String             @default("") @map("arquivo_nome") @db.VarChar(500)
  titulo         String             @default("") @db.VarChar(500)
  artista        String             @default("") @db.VarChar(500)
  /// Chave relativa no disco cloud2 (download-staging:…)
  storageKey     String?            @map("storage_key") @db.VarChar(300)
  sizeBytes      Int?               @map("size_bytes")
  providerRef    String             @default("") @map("provider_ref") @db.VarChar(200)
  erroMsg        String             @default("") @map("erro_msg") @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  job DownloadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([status, createdAt])
  @@map("download_item")
}
