// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Um único registro com os tokens OAuth da empresa conectada ao Conta Azul.
model ContaAzulToken {
  id           String   @id @default("default")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("conta_azul_token")
}

/// Anotações do portal por cliente Conta Azul (id da pessoa). Persistem no Postgres mesmo quando
/// o cliente deixa de aparecer na listagem (ex.: zerou pendências na Conta Azul).
model ClientPortalMeta {
  clientId          String   @id @map("client_id")
  hasActiveContract Boolean  @default(false) @map("has_active_contract")
  note              String   @default("")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("client_portal_meta")
}

/// Status do fluxo OC / envio para um cliente num mês.
enum ManualReminderRowStatus {
  pendente
  solicitado_ordem
  enviado
}

/// Modelo de linhas (novos meses copiam daqui).
model ManualReminderTemplate {
  id              String   @id @default(cuid())
  emissionDay     Int      @map("emission_day")
  clienteNome     String   @map("cliente_nome")
  cnpjDocumento   String?  @map("cnpj_documento")
  solicitarPedirOc Boolean @default(true) @map("solicitar_pedir_oc")
  spreadsheetHint String?  @map("spreadsheet_hint")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("manual_reminder_template")
}

/// Instância mensal (aba “Maio/2026”, etc.).
model ManualReminderMonth {
  id        String   @id @default(cuid())
  yearMonth Int      @unique @map("year_month")
  createdAt DateTime @default(now()) @map("created_at")

  linhas ManualReminderRow[]

  @@map("manual_reminder_month")
}

model ManualReminderRow {
  id                 String                  @id @default(cuid())
  monthId            String                  @map("month_id")
  month              ManualReminderMonth     @relation(fields: [monthId], references: [id], onDelete: Cascade)

  emissionDay        Int                     @map("emission_day")
  clienteNome        String                  @map("cliente_nome")
  cnpjDocumento      String?                 @map("cnpj_documento")
  contaAzulPersonId  String?                 @map("conta_azul_person_id")

  solicitarPedirOc   Boolean                 @default(true) @map("solicitar_pedir_oc")
  status             ManualReminderRowStatus @default(pendente)

  emailCobranca      String?                 @map("email_cobranca")
  spreadsheetHint    String?                 @map("spreadsheet_hint")
  notes              String                  @default("")

  /// YYYYMMDD (TZ Brasil): último envio automático OC; impede segundo disparo no mesmo dia (reset ao voltar para pendente).
  autoOcSentYmd      Int?                    @map("auto_oc_sent_ymd")

  sortOrder          Int                     @default(0) @map("sort_order")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  @@index([monthId, emissionDay, sortOrder])
  @@map("manual_reminder_row")
}

/// Modelo único de e-mail para pedido de OC (Envios manuais). Id fixo `default`.
model OcEmailTemplate {
  id        String   @id
  subject   String
  bodyText  String   @map("body_text") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("oc_email_template")
}

/// Template do e-mail agregado «cobranças em aberto» na homepage (usa mesmo SMTP OC_*).
model CobrancaAbertaEmailTemplate {
  id        String   @id
  subject   String   @db.VarChar(480)
  bodyText  String   @map("body_text") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cobranca_aberta_email_template")
}

// --- Planilha Rio (visão competência mês a mês, amarrada ao Conta Azul) ---

enum RioPlanilhaBand {
  canceladas
  novos
  ativos
}

enum RioPlanilhaRowKind {
  secao
  grupo
  pdv
}

enum RioChargeMode {
  herda_grupo
  cliente_ca_proprio
}

model RioPlanilhaMonth {
  id        String   @id @default(cuid())
  yearMonth Int      @unique @map("year_month")
  createdAt DateTime @default(now()) @map("created_at")

  linhas RioPlanilhaRow[]

  @@map("rio_planilha_month")
}

model RioPlanilhaRow {
  id      String           @id @default(cuid())
  monthId String           @map("month_id")
  month   RioPlanilhaMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  band RioPlanilhaBand
  kind RioPlanilhaRowKind

  parentId String? @map("parent_id")
  parent   RioPlanilhaRow?  @relation("RioPdvParent", fields: [parentId], references: [id], onDelete: Cascade)
  children RioPlanilhaRow[] @relation("RioPdvParent")

  /// Só em linhas `secao` — título da faixa (ex.: lojas canceladas).
  tituloSecao String? @map("titulo_secao") @db.Text

  marca          String  @default("")
  numOrdem       Int?    @map("num_ordem")
  pdvNome        String  @default("") @map("pdv_nome")
  cnpjDocumento  String? @map("cnpj_documento")
  status         String  @default("")
  valorTexto     String? @map("valor_texto")
  qtdeTexto      String? @map("qtde_texto")
  categoria      String  @default("")
  email          String? @db.Text
  dataInstall    String? @map("data_install")
  grupoCobranca  String  @default("") @map("grupo_cobranca") @db.Text
  razao          String  @default("") @db.Text
  dataCancel     String? @map("data_cancel")
  notes          String  @default("") @db.Text

  contaAzulPersonId String? @map("conta_azul_person_id")

  /// Em `pdv`: fatura pelo grupo (matriz) vs cliente próprio no CA.
  chargeMode RioChargeMode @default(herda_grupo) @map("charge_mode")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([monthId, sortOrder])
  @@index([monthId, band, sortOrder])
  @@map("rio_planilha_row")
}

/// --- Planilha Rio v2 — competências com clientes ativos Conta Azul + PDVs geridos no portal ---

enum RioClienteCompMovimento {
  estavel
  entrada
  saida
}

model RioCompMonth {
  id           String    @id @default(cuid())
  yearMonth    Int       @unique @map("year_month")
  lastSyncedAt DateTime? @map("last_synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  grupos RioCompGrupo[]
  linhas RioCompClienteLinha[]

  @@map("rio_comp_month")
}

/// Marca agrupadora (PDF «MARCA») — arrastar clientes dentro no painel Rio.
model RioCompGrupo {
  id       String       @id @default(cuid())
  monthId  String       @map("month_id")
  month    RioCompMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  nome      String @default("") @map("nome") @db.Text
  sortOrder Int    @default(0) @map("sort_order")

  linhas RioCompClienteLinha[]

  @@index([monthId, sortOrder])
  @@map("rio_comp_grupo")
}

model RioCompClienteLinha {
  id       String       @id @default(cuid())
  monthId  String       @map("month_id")
  month    RioCompMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)

  rioGrupoId String?        @map("rio_grupo_id")
  rioGrupo   RioCompGrupo? @relation(fields: [rioGrupoId], references: [id], onDelete: SetNull)

  caPersonId String @map("ca_person_id")

  /// Agrupamento interno — não existe no ERP.
  grupoSite String @default("") @map("grupo_site") @db.Text

  nomeFantasia   String @default("") @map("nome_fantasia") @db.Text
  razaoSocial    String @default("") @map("razao_social") @db.Text
  documento      String? @db.VarChar(64)
  emailCobranca  String? @map("email_cobranca") @db.Text

  // Texto livre (ex.: valor vindo da API CA ou traco)
  valorClienteTexto String @default("") @map("valor_cliente_texto") @db.VarChar(200)

  numeroPdvSite Int    @default(0) @map("numero_pdv_site")
  categoriaSite String @default("") @map("categoria_site") @db.VarChar(120)

  /// Número(s) de contratos ATIVO no CA quando sincronizou (lista separada por vírgulas).
  contratosAtivosTexto String @default("") @map("contratos_ativos_texto") @db.VarChar(400)

  movimento RioClienteCompMovimento @default(estavel)

  observacoesLinha String @default("") @map("observacoes_linha") @db.Text
  sortOrder        Int                   @default(0) @map("sort_order")

  pdvs RioCompPdv[]

  @@unique([monthId, caPersonId])
  @@index([monthId, sortOrder])
  @@map("rio_comp_cliente_linha")
}

model RioCompPdv {
  id        String              @id @default(cuid())
  clienteId String              @map("cliente_id")
  cliente   RioCompClienteLinha @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  nome      String @default("") @db.Text
  notes     String @default("") @db.Text
  sortOrder Int    @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clienteId, sortOrder])
  @@map("rio_comp_pdv")
}
